            RowBox[{"{", 
             RowBox[{
              RowBox[{"c1", "->", "0"}], ",", 
              RowBox[{"c2", "->", "0"}], ",", 
              RowBox[{"c3", "->", "0"}], ",", 
              RowBox[{"c4", "->", "0"}], ",", 
              RowBox[{"s1", "->", "0"}], ",", 
              RowBox[{"s2", "->", 
               RowBox[{"variableData", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "1"}], "]"}], "]"}]}], ",", 
              RowBox[{"s0n", "->", "0"}], ",", 
              RowBox[{"en", "->", "Te"}]}], "}"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Max", "[", 
           RowBox[{"Re", "[", 
            RowBox[{"Eigenvalues", "[", "JacVal", "]"}], "]"}], "]"}]}], ",", 
         
         RowBox[{"(*", 
