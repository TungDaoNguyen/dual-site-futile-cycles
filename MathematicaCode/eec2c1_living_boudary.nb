                RowBox[{
                "TsVal", ",", "c1Val", ",", "c2Val", ",", "c3Val", ",", 
                 "c4Val", ",", "eVal", ",", "s0Val", ",", "s1Val", ",", 
                 "s2Val", ",", "stable"}], "}"}]}], "]"}], ";"}]}], "]"}]}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"root", ",", "roots"}], "}"}]}], "]"}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"TsVal", ",", "TsValues"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Computation complete. Processing data...\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", 
     RowBox[{"==", 
      RowBox[{"NETWORK", " ", "NAME"}]}], "===", "=="}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"networkName", "=", "\"\<eec2c1_2pss_living_boundary\>\""}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"===", 
     RowBox[{"==", 
      RowBox[{"EXPORT", " ", "DATA"}]}], "===", "=="}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Separate", " ", "stable", " ", "and", " ", "unstable", " ", "branches"}],
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"stableBranch", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"stabilityData", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "==", "True"}], "&"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"unstableBranch", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"stabilityData", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "==", "False"}], "&"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Prepare", " ", "data", " ", "for", " ", "export"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stableData", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{"variableData", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "10", "]"}], "]"}], "==", "True"}], "&"}]}], "]"}], 
       ",", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{
         RowBox[{"{", "1", "}"}], ",", 
         RowBox[{"Length", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"variableData", ",", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "10", "]"}], "]"}], "==", "True"}], "&"}]}], 
           "]"}], "]"}]}], "]"}], ",", "2"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"unstableData", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{"variableData", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "10", "]"}], "]"}], "==", "False"}], "&"}]}], "]"}], 
       ",", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{
         RowBox[{"{", "0", "}"}], ",", 
         RowBox[{"Length", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"variableData", ",", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "10", "]"}], "]"}], "==", "False"}], "&"}]}], 
           "]"}], "]"}]}], "]"}], ",", "2"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"allData", "=", 
     RowBox[{"Join", "[", 
      RowBox[{"stableData", ",", "unstableData"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Create", " ", "header"}], "-", 
     RowBox[{"note", " ", "v", " ", "is", " ", "NOT", " ", "included"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"header", "=", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Ts\>\"", ",", "\"\<c1\>\"", ",", "\"\<c2\>\"", ",", "\"\<c3\>\"", 
       ",", "\"\<c4\>\"", ",", "\"\<e\>\"", ",", "\"\<s0\>\"", ",", 
       "\"\<s1\>\"", ",", "\"\<s2\>\"", ",", "\"\<stable\>\"", ",", 
       "\"\<stability_flag\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Export", " ", "bifurcation", " ", "data", " ", "to", " ", "CSV"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{
      "exportDir", "<>", "networkName", "<>", "\"\<_bifdata.csv\>\""}], ",", 
      RowBox[{"Prepend", "[", 
       RowBox[{"allData", ",", "header"}], "]"}], ",", "\"\<CSV\>\""}], "]"}],
     ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Export", " ", "eigenvalue", " ", "data"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eigenData", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"stabilityData", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"(*", "Ts", "*)"}], 
         RowBox[{"(*", 
          RowBox[{"Recalculate", " ", "v", " ", "and", " ", "eigenvalue"}], 
          "*)"}], 
         RowBox[{
          RowBox[{"vVals", "=", 
           RowBox[{"NSolve", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"p", "[", 
                RowBox[{"v", ",", 
                 RowBox[{"stabilityData", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}], "==", 
               "0"}], "&&", 
              RowBox[{"v", ">", "0"}]}], ",", "v", ",", "Reals"}], "]"}]}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", "vVals", "]"}], ">", "0"}], ",", 
            RowBox[{"Max", "[", 
             RowBox[{"Re", "[", 
              RowBox[{"Eigenvalues", "[", 
               RowBox[{"Jsub", "[", 
                RowBox[{"v", "/.", " ", 
                 RowBox[{"vVals", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "]"}], "]"}], 
             "]"}], ",", "0"}], "]"}]}], ",", 
         RowBox[{"(*", 
          RowBox[{"max", " ", "real", " ", "part"}], "*)"}], 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"stabilityData", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "2"}], "]"}], "]"}], ",", "1", ",", "0"}], 
          "]"}]}], "  ", 
        RowBox[{"(*", 
         RowBox[{"stability", " ", "flag"}], "*)"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"Length", "[", "stabilityData", "]"}]}], "}"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{
      "exportDir", "<>", "networkName", "<>", "\"\<_eigdata.csv\>\""}], ",", 
      RowBox[{"Prepend", "[", 
       RowBox[{"eigenData", ",", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Ts\>\"", ",", "\"\<max_Re_lambda\>\"", ",", "\"\<stable\>\""}], 
         "}"}]}], "]"}], ",", "\"\<CSV\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Data exported successfully to: \>\"", ",", "exportDir"}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<Files created: \>\"", "<>", "networkName", "<>", 
      "\"\<_bifdata.csv, \>\"", "<>", "networkName", "<>", 
      "\"\<_eigdata.csv\>\""}], "]"}], ";"}]}]}]], "Input",
