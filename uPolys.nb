 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{
    "u_", ",", "k1_", ",", "k2_", ",", "k3_", ",", "k4_", ",", "k1s_", ",", 
     "k2s_", ",", "k3s_", ",", "k4s_", ",", "Te_", ",", "Ts_"}], "]"}], ":=", 
   
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "gamma", ",", "alpha0", ",", "alpha1", ",", "alpha2", ",", "beta3", ",",
