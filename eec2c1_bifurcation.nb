             "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{"Determine", " ", "stability"}], "*)"}], 
             RowBox[{"stable", "=", 
              RowBox[{"maxRealPart", "<", "0"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Calculate", " ", "v1", " ", "and", " ", "v2", " ", "values"}], 
              "*)"}], 
             RowBox[{"v1Val", "=", "v1"}], ";", "\[IndentingNewLine]", 
             RowBox[{"v2Val", "=", "v2"}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Calculate", " ", "c", " ", "from", " ", "the", " ", 
               "definition"}], "*)"}], 
             RowBox[{"cVal", "=", 
              RowBox[{"Te", "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"k2", "/", "k1"}], ")"}], "*", 
                  RowBox[{"(", 
                   RowBox[{"ks4", "/", "ks2"}], ")"}], "*", 
                  RowBox[{"(", 
                   RowBox[{"1", "/", "v1Val"}], ")"}]}], "+", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"1", "+", 
                    RowBox[{"k1", "/", "k4"}]}], ")"}], "*", "uVal"}], "+", 
                 RowBox[{"(", 
                  RowBox[{"1", "+", 
                   RowBox[{"k2", "/", "k3"}]}], ")"}]}], ")"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{"Calculate", " ", "other", " ", "variables"}], "*)"}], 
             RowBox[{"c1Val", "=", 
              RowBox[{"cVal", "*", "uVal"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"c2Val", "=", "cVal"}], ";", "\[IndentingNewLine]", 
             RowBox[{"c3Val", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"k2", "/", "k3"}], ")"}], "*", "cVal"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"c4Val", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"k1", "/", "k4"}], ")"}], "*", "uVal", "*", 
               "cVal"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"eVal", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"k2", "/", "k1"}], ")"}], "*", 
               RowBox[{"(", 
                RowBox[{"ks4", "/", "ks2"}], ")"}], "*", 
               RowBox[{"(", 
                RowBox[{"cVal", "/", "v1Val"}], ")"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"s1Val", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"k1", "/", "ks4"}], ")"}], "*", "v1Val"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"s2Val", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"k2", "/", "ks3"}], ")"}], "*", "v2Val"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Calculate", " ", "s0", " ", "from", " ", "conservation", " ", 
               "law"}], "*)"}], 
             RowBox[{"s0Val", "=", 
              RowBox[{
              "TsVal", "-", "s1Val", "-", "s2Val", "-", "c1Val", "-", "c2Val",
                "-", 
               RowBox[{"2", "*", "c3Val"}], "-", 
               RowBox[{"2", "*", "c4Val"}]}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{"Store", " ", "data"}], "*)"}], 
             RowBox[{"AppendTo", "[", 
              RowBox[{"bifurcationData", ",", 
               RowBox[{"{", 
                RowBox[{"TsVal", ",", "uVal"}], "}"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"stabilityData", ",", 
               RowBox[{"{", 
                RowBox[{"TsVal", ",", "uVal", ",", "stable"}], "}"}]}], "]"}],
              ";", "\[IndentingNewLine]", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"variableData", ",", 
               RowBox[{"{", 
                RowBox[{
                "TsVal", ",", "uVal", ",", "c1Val", ",", "c2Val", ",", 
                 "c3Val", ",", "c4Val", ",", "eVal", ",", "s0Val", ",", 
                 "s1Val", ",", "s2Val", ",", "stable"}], "}"}]}], "]"}], 
             ";"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"root", ",", "roots"}], "}"}]}], "]"}], ";"}], ",", 
      RowBox[{"{", 
       RowBox[{"TsVal", ",", "TsValues"}], "}"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Computation complete. Processing data...\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", 
     RowBox[{"==", 
      RowBox[{"NETWORK", " ", "NAME"}]}], "===", "=="}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"networkName", "=", "\"\<eec2c1_2pss\>\""}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"===", 
     RowBox[{"==", 
      RowBox[{"EXPORT", " ", "DATA"}]}], "===", "=="}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Separate", " ", "stable", " ", "and", " ", "unstable", " ", "branches"}],
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"stableBranch", "=", 
     RowBox[{
      RowBox[{"Select", "[", 
       RowBox[{"stabilityData", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "3", "]"}], "]"}], "==", "True"}], "&"}]}], "]"}], 
      "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"unstableBranch", "=", 
     RowBox[{
      RowBox[{"Select", "[", 
       RowBox[{"stabilityData", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "3", "]"}], "]"}], "==", "False"}], "&"}]}], "]"}], 
      "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Prepare", " ", "data", " ", "for", " ", "export"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stableData", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{"variableData", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "11", "]"}], "]"}], "==", "True"}], "&"}]}], "]"}], 
       ",", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{
         RowBox[{"{", "1", "}"}], ",", 
         RowBox[{"Length", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"variableData", ",", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "11", "]"}], "]"}], "==", "True"}], "&"}]}], 
           "]"}], "]"}]}], "]"}], ",", "2"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"unstableData", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{"variableData", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "11", "]"}], "]"}], "==", "False"}], "&"}]}], "]"}], 
       ",", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{
         RowBox[{"{", "0", "}"}], ",", 
         RowBox[{"Length", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"variableData", ",", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "11", "]"}], "]"}], "==", "False"}], "&"}]}], 
           "]"}], "]"}]}], "]"}], ",", "2"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"allData", "=", 
     RowBox[{"Join", "[", 
      RowBox[{"stableData", ",", "unstableData"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Create", " ", "header"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"header", "=", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Ts\>\"", ",", "\"\<u\>\"", ",", "\"\<c1\>\"", ",", "\"\<c2\>\"", 
       ",", "\"\<c3\>\"", ",", "\"\<c4\>\"", ",", "\"\<e\>\"", ",", 
       "\"\<s0\>\"", ",", "\"\<s1\>\"", ",", "\"\<s2\>\"", ",", 
       "\"\<stable\>\"", ",", "\"\<stability_flag\>\""}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Export", " ", "bifurcation", " ", "data", " ", "to", " ", "CSV"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{
      "exportDir", "<>", "networkName", "<>", "\"\<_bifdata.csv\>\""}], ",", 
      RowBox[{"Prepend", "[", 
       RowBox[{"allData", ",", "header"}], "]"}], ",", "\"\<CSV\>\""}], "]"}],
     ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Export", " ", "eigenvalue", " ", "data"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eigenData", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"stabilityData", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"(*", "Ts", "*)"}], 
         RowBox[{"stabilityData", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "2"}], "]"}], "]"}], ",", 
         RowBox[{"(*", "u", "*)"}], 
         RowBox[{"Max", "[", 
          RowBox[{"Re", "[", 
           RowBox[{"Eigenvalues", "[", 
            RowBox[{"Jsub", "[", 
             RowBox[{"stabilityData", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "2"}], "]"}], "]"}], "]"}], "]"}], "]"}], 
          "]"}], ",", 
         RowBox[{"(*", 
          RowBox[{"max", " ", "real", " ", "part"}], "*)"}], 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"stabilityData", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "3"}], "]"}], "]"}], ",", "1", ",", "0"}], 
          "]"}]}], "  ", 
        RowBox[{"(*", 
         RowBox[{"stability", " ", "flag"}], "*)"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"Length", "[", "stabilityData", "]"}]}], "}"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{
      "exportDir", "<>", "networkName", "<>", "\"\<_eigdata.csv\>\""}], ",", 
      RowBox[{"Prepend", "[", 
       RowBox[{"eigenData", ",", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Ts\>\"", ",", "\"\<u\>\"", ",", "\"\<max_Re_lambda\>\"", ",", 
          "\"\<stable\>\""}], "}"}]}], "]"}], ",", "\"\<CSV\>\""}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Data exported successfully to: \>\"", ",", "exportDir"}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<Files created: \>\"", "<>", "networkName", "<>", 
      "\"\<_bifdata.csv, \>\"", "<>", "networkName", "<>", 
      "\"\<_eigdata.csv\>\""}], "]"}], ";"}]}]}]], "Input",
